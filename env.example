# Hormiga Scalper v1 — example environment (DO NOT put real secrets in git)

# Autotrader
AUTOTRADE=true
AUTOTRADE_MODE=live

# Risk / sizing
TRADE_USD=5
MAX_DAILY_LOSS_USD=5
MAX_TRADES_TOTAL=2
MAX_TRADES_PER_HOUR=3
COOLDOWN_SECONDS=180
MIN_SECONDS_LEFT=300
MAX_SPREAD_SUM=0.60
TP_PERCENT=0.03
SL_PERCENT=0.05
MAX_HOLD_SECONDS=180
SESSION_DURATION_MINUTES=30

# Polymarket CLOB (required)
CLOB_API_KEY=
CLOB_API_SECRET=
CLOB_API_PASSPHRASE=
PRIVATE_KEY=
POLY_SIGNATURE_TYPE=eoa
POLY_FUNDER_ADDRESS=

# Telegram (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Budget / allocation (optional)
BASE_CAPITAL_USDC=50
BTC_SESSION_BUDGET_USD=25
F1_BUDGET_PCT=0.35
F1_BUDGET_PCT_NEXT=0.40
